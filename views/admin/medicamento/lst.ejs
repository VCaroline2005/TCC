<%-include('../cabecalho.ejs')%>
<section class="col-12 col-md-10">
    <div class="card my-4">
        <h5 class="card-header">Lista de Medicamentos</h5>
        <div class="card-body">
            <form method="post" class="form-inline">
                <div class="form-group mb-2">
                    <label for="pesquisar" class="sr-only">Pesquisar</label>
                    <input type="text" class="form-control" id="pesquisar" placeholder="Pesquisar" name="pesquisar">
                </div>
                <button type="submit" class="btn btn-primary mb-2">Pesquisar</button>
            </form>
            <table class="table table-striped table-hover table-dark">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Nome</th>
                        <th>Descrição</th>
                        <th>Dosagem</th>
                        <th>Via</th>
                        <th>Edit</th>
                        <th>Del</th>
                    </tr>
                </thead>
                <tbody>
                    <%Medicamentos.forEach(function(m){%>
                    <tr>
                        <td><%=m._id%></td>
                        <td><%=m.nome%></td>
                        <td><%=m.descricao%></td>
                        <td><%=m.dosagem%></td>
                        <td><%=m.via%></td>
                        <td><a href="/admin/medicamento/edt/<%=m._id%>">Editar</a></td>
                        <td><a href="/admin/medicamento/del/<%=m._id%>">Deletar</a></td>
                    </tr>
                    <%})%>
                </tbody>
            </table>
        </div>
    </div>
</section>
<%-include('../rodape.ejs')%>

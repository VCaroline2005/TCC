<%-include('../cabecalho.ejs')%>
<section class="col-12 col-md-10">
    <div class="card my-4">
        <h5 class="card-header">Revisar Importação (PDF)</h5>
        <div class="card-body">
            <% if (erro) { %>
                <div class="alert alert-danger" role="alert">
                    <%= erro %>
                </div>
            <% } %>

            <% if (aviso) { %>
                <div class="alert alert-warning" role="alert">
                    <%= aviso %>
                </div>
            <% } %>

            <p class="text-muted">
                Revise os campos abaixo antes de salvar. Você pode corrigir valores e decidir se já quer publicar.
            </p>

            <form method="post" action="/admin/medicamento/import/confirmar/<%= encodeURIComponent(importId) %>">
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="checkbox" value="1" id="publicar" name="publicar">
                    <label class="form-check-label" for="publicar">
                        Publicar automaticamente ao salvar
                    </label>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover table-dark">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Princípio Ativo</th>
                                <th>Nome Comercial</th>
                                <th>Classe</th>
                                <th>Via</th>
                                <th>Diluição</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% medicamentos.forEach(function(m, idx){ %>
                                <tr>
                                    <td><%= idx + 1 %></td>
                                    <td>
                                        <input class="form-control" type="text" name="medicamentos[<%= idx %>][principioAtivo]" value="<%= m.principioAtivo || '' %>">
                                    </td>
                                    <td>
                                        <input class="form-control" type="text" required name="medicamentos[<%= idx %>][nomeComercial]" value="<%= m.nomeComercial || '' %>">
                                    </td>
                                    <td>
                                        <input class="form-control" type="text" name="medicamentos[<%= idx %>][classe]" value="<%= m.classe || '' %>">
                                    </td>
                                    <td>
                                        <input class="form-control" type="text" name="medicamentos[<%= idx %>][via]" value="<%= m.via || '' %>">
                                    </td>
                                    <td>
                                        <input class="form-control" type="text" name="medicamentos[<%= idx %>][diluicao]" value="<%= m.diluicao || '' %>">
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Salvar importação</button>
                    <a class="btn btn-secondary" href="/admin/medicamento/import">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</section>
<%-include('../rodape.ejs')%>

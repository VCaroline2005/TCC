<%-include('../cabecalho.ejs')%>
<section class="col-12 col-md-10">
    <div class="card my-4">
        <h5 class="card-header">Lista de Terminologias</h5>
        <div class="card-body">

            <form method="post" class="form-inline">
                <div class="form-group mb-2">
                    <label for="pesquisar" class="sr-only">Pesquisar</label>
                    <input type="text" class="form-control" id="pesquisar" placeholder="Pesquisar" name="pesquisar">
                </div>
                <button type="submit" class="btn btn-primary mb-2">Pesquisar</button>
            </form>

            <table class="table table-striped table-hover table-dark">
                <thead>
                    <tr>
                        <th scope="col">Id</th>
                        <th scope="col">Termo</th>
                        <th scope="col">Definição</th>
                        <th scope="col">Categoria</th>
                        <th scope="col">Publicado</th>
                        <th scope="col">Publicação</th>
                        <th scope="col">Editar</th>
                        <th scope="col">Deletar</th>
                    </tr>
                </thead>
                <tbody>
                    <%Termos.forEach(function(termo){%>
                    <tr>
                        <th scope="row"> <%=termo._id%> </th>
                        <td> <%=termo.termo%> </td>
                        <td> <%=termo.definicao%> </td>
                        <td> <%=termo.categoria%> </td>
                        <td> <%=termo.publicado ? 'Sim' : 'Não'%> </td>
                        <td>
                            <% if(termo.publicado){ %>
                                <a href="/admin/terminologia/unpub/<%=termo._id%>">Despublicar</a>
                            <% } else { %>
                                <a href="/admin/terminologia/pub/<%=termo._id%>">Publicar</a>
                            <% } %>
                        </td>
                        <td><a href="/admin/terminologia/edt/<%=termo._id%>">Editar</a></td>
                        <td><a href="/admin/terminologia/del/<%=termo._id%>">Deletar</a></td>
                    </tr>
                    <%})%>
                </tbody>
            </table>
        </div>
    </div>
</section>
<%-include('../rodape.ejs')%>

            <a class="navbar-brand" href="/admin/usuarios/lst">
                <img src="/site/img/logo.png" height="46" alt="Portal Enfermagem">
            </a>
            <ul class="navbar-nav mr-auto mt-2 mt-lg-0">
                <li class="nav-item"><a class="nav-link" href="/admin/usuarios/lst">Usuários</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/terminologia/lst">Terminologias</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/procedimento/lst">Procedimentos</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/medicamento/lst">Medicamentos</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/quiz/lst">Quiz</a></li>
            </ul>
            <div class="admin-controls">
                <button type="button" class="nav-btn" onclick="history.back()">Voltar</button>
                <a class="nav-btn" href="/login">Sair</a>
                <button type="button" class="nav-btn" onclick="history.forward()">Avançar</button>
            </div>
        </div>
    </nav>

    <div class="row admin-layout">
        <aside class="col-12 col-md-2 admin-sidebar">
            <ul class="nav flex-column">
                <li class="nav-item"><a class="nav-link" href="/admin/usuarios/lst">Listar usuários</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/categoria/lst">Categorias</a></li>

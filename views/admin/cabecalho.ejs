<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.1.3/css/bootstrap.min.css"
        integrity="sha384-MCw98/SFnGE8fJT3GXwEOngsV7Zt27NXFoaoApmYm81iuXoPkFOJwJ8ERdknLPMO" crossorigin="anonymous">

    <title>Portal Enfermagem - Administração</title>
    <style>
        :root {
            --admin-red: #a51b0b;
            --admin-black: #111111;
            --admin-white: #ffffff;
            --admin-soft: #f7f7f7;
            --admin-line: #d8d8d8;
        }

        body {
            background: var(--admin-soft);
            color: var(--admin-black);
        }

        .admin-topbar {
            background: linear-gradient(90deg, #a51b0b 0%, #6f1208 45%, #160504 100%);
            box-shadow: 0 3px 12px rgba(0, 0, 0, 0.18);
        }

        .admin-topbar .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.3px;
        }

        .admin-topbar .navbar-brand img {
            height: 46px;
            width: auto;
            filter: drop-shadow(0 2px 6px rgba(0,0,0,0.35));
        }

        .admin-topbar .nav-link {
            color: #ffe9e6 !important;
            font-weight: 600;
        }

        .admin-topbar .nav-link:hover {
            color: #ffffff !important;
        }

        .admin-controls {
            display: flex;
            gap: 8px;
            margin-left: auto;
            flex-wrap: wrap;
        }

        .admin-controls .nav-btn {
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.28);
            color: #fff;
            padding: 6px 10px;
            border-radius: 6px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
        }

        .admin-controls .nav-btn:hover {
            background: rgba(255,255,255,0.22);
            color: #fff;
            text-decoration: none;
        }

        .admin-layout {
            margin: 0;
            min-height: calc(100vh - 76px);
        }

        .admin-sidebar {
            background: var(--admin-white);
            border-right: 1px solid var(--admin-line);
            padding: 20px 0;
        }

        .admin-sidebar .nav-link {
            color: var(--admin-black);
            border-left: 4px solid transparent;
            padding: 10px 16px;
            font-weight: 600;
        }

        .admin-sidebar .nav-link:hover {
            background: #fff1ef;
            color: var(--admin-red);
            border-left-color: var(--admin-red);
        }

        section.col-12.col-md-10 {
            padding: 24px;
        }

        .card {
            border: 1px solid var(--admin-line);
            border-radius: 10px;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
        }

        .card-header {
            background: var(--admin-red);
            color: var(--admin-white);
            font-weight: 700;
            border-bottom: 0;
        }

        .table-dark {
            background: var(--admin-white) !important;
            color: var(--admin-black) !important;
        }

        .table-dark th,
        .table-dark td,
        .table-dark thead th {
            border-color: var(--admin-line) !important;
            color: var(--admin-black) !important;
        }

        .table-hover tbody tr:hover {
            background-color: #fff1ef !important;
            color: var(--admin-black) !important;
        }

        .btn-primary {
            background-color: var(--admin-red);
            border-color: var(--admin-red);
        }

        .btn-primary:hover {
            background-color: #8a1609;
            border-color: #8a1609;
        }

        a {
            color: var(--admin-red);
            font-weight: 600;
        }

        a:hover {
            color: #7a1408;
            text-decoration: none;
        }

        @media (max-width: 767px) {
            .admin-sidebar {
                border-right: 0;
                border-bottom: 1px solid var(--admin-line);
            }

            section.col-12.col-md-10 {
                padding: 12px;
            }
        }
    </style>
</head>

<body>

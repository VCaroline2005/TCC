<%-include('../cabecalho.ejs')%>
<section class="col-12 col-md-10">
    <div class="card my-4">
        <h5 class="card-header">Lista de Procedimentos</h5>
        <div class="card-body">

            <form method="post" class="form-inline">
                <div class="form-group mb-2">
                    <label for="pesquisar" class="sr-only">Pesquisar</label>
                    <input type="text" class="form-control" id="pesquisar" placeholder="Pesquisar" name="pesquisar">
                </div>
                <button type="submit" class="btn btn-primary mb-2">Pesquisar</button>
            </form>

            <table class="table table-striped table-hover table-dark">
                <thead>
                    <tr>
                        <th scope="col">Id</th>
                        <th scope="col">Nome</th>
                        <th scope="col">Categoria</th>
                        <th scope="col">Fotos</th>
                        <th scope="col">Publicado</th>
                        <th scope="col">Publicação</th>
                        <th scope="col">Editar</th>
                        <th scope="col">Deletar</th>
                    </tr>
                </thead>
                <tbody>
                    <%Procedimentos.forEach(function(procedimento){%>

                    <tr>
                        <th scope="row"> <%=procedimento._id%> </th>
                        <td> <%=procedimento.nome%> </td>
                        <td> <%=procedimento.categoria%> </td>
                        <td>
                            <%procedimento.fotos.forEach(function(foto){%>
                                <img src="/fotos/<%=foto%>" height="40px" alt="Fotos">  
                            <%})%>
                        </td>
                        <td><%=procedimento.publicado ? 'Sim' : 'Não'%></td>
                        <td>
                            <% if(procedimento.publicado){ %>
                                <a href="/admin/procedimento/unpub/<%=procedimento._id%>">Despublicar</a>
                            <% } else { %>
                                <a href="/admin/procedimento/pub/<%=procedimento._id%>">Publicar</a>
                            <% } %>
                        </td>
                        <td>
                            <a href="/admin/procedimento/edt/<%=procedimento._id%>">Editar</a>
                        </td>
                        <td>
                            <a href="/admin/procedimento/del/<%=procedimento._id%>">Deletar</a>
                        </td>
                    </tr>

                    <%})%>

                </tbody>
            </table>
        </div>
    </div>
</section>
<%-include('../rodape.ejs')%>

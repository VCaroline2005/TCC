<%-include('../cabecalho.ejs')%>
<section class="col-12 col-md-10">
    <div class="card my-4">
        <h5 class="card-header">Importar POPs (PDF)</h5>
        <div class="card-body">
            <% if (erro) { %>
                <div class="alert alert-danger" role="alert">
                    <%= erro %>
                </div>
            <% } %>

            <% if (resultado) { %>
                <div class="alert alert-success" role="alert">
                    Importação concluída: <%= resultado.inseridos %> POP(s) criado(s).
                </div>
            <% } %>

            <p class="text-muted">
                Envie um ou mais PDFs (um POP por arquivo). O sistema cria os procedimentos automaticamente usando o nome do arquivo.
            </p>

            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="arquivos" class="form-label">Arquivos PDF</label>
                    <input type="file" name="arquivos" id="arquivos" accept="application/pdf,.pdf" multiple required class="form-control">
                </div>
                <div class="mb-3 form-check">
                    <input class="form-check-input" type="checkbox" value="1" id="publicar" name="publicar" checked>
                    <label class="form-check-label" for="publicar">
                        Publicar automaticamente
                    </label>
                </div>

                <div class="mb-3">
                    <input type="submit" value="Importar POPs" class="btn btn-primary">
                    <a class="btn btn-secondary" href="/admin/procedimento/lst">Voltar</a>
                </div>
            </form>
        </div>
    </div>
</section>
<%-include('../rodape.ejs')%>


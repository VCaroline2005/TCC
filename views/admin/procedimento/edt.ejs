<%-include('../cabecalho.ejs')%>
<section class="col-12 col-md-10">
    <div class="card my-4">
        <h5 class="card-header">Editar Procedimento</h5>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label for="id" class="form-label">ID</label>
                    <input type="text" name="id" readonly id="id" class="form-control" value="<%=Procedimento._id%>">
                </div>
                <div class="mb-3">
                    <label for="nome" class="form-label">Nome</label>
                    <input type="text" name="nome" required id="nome" class="form-control" value="<%=Procedimento.nome%>">
                </div>
                <div class="mb-3">
                    <label for="descricao" class="form-label">Descrição</label>
                    <textarea name="descricao" required id="descricao" class="form-control"><%=Procedimento.descricao%></textarea>
                </div>
                <div class="mb-3">
                    <label for="passos" class="form-label">Passos (um por linha)</label>
                    <textarea name="passos" id="passos" class="form-control"><%=Procedimento.passos ? Procedimento.passos.join('\n') : '' %></textarea>
                </div>
                <div class="mb-3">
                    <label for="categoria" class="form-label">Categoria</label>
                    <input type="text" name="categoria" required id="categoria" class="form-control" value="<%=Procedimento.categoria%>">
                </div>
                <div class="mb-3">
                    <input type="submit" value="Adicionar" class="form-control">
                </div>
            </form>
        </div>
    </div>
</section>
<%-include('../rodape.ejs')%>
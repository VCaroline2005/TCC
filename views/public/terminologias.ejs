<%- include('cabecalho', { pageClass: 'page-terminologias' }) %>
<% const pesquisaAtual = (typeof pesquisar !== 'undefined' && pesquisar) ? pesquisar : ''; %>
<h2>Terminologias</h2>
<form method="get" action="/terminologias" class="filter-form">
  <input
    type="text"
    name="pesquisar"
    placeholder="Pesquisar termo, definição ou categoria"
    value="<%= pesquisaAtual %>"
    class="filter-input"
  >
  <button type="submit" class="filter-btn">
    Pesquisar
  </button>
</form>
<ul>
  <% Termos.forEach(function(t){ %>
    <li><strong><%= t.termo %></strong>: <%= t.definicao %></li>
  <% }) %>
</ul>
<%- include('rodape') %>

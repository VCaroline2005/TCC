<%- include('cabecalho', { pageClass: 'page-usuario-editar' }) %>
<h2>Editar meus dados</h2>

<% if (typeof erro !== 'undefined' && erro === 'email') { %>
  <p class="form-error">E-mail já cadastrado.</p>
<% } %>
<% if (typeof erro !== 'undefined' && erro === 'salvar') { %>
  <p class="form-error">Não foi possível salvar. Tente novamente.</p>
<% } %>

<form method="post" action="/usuario/editar" enctype="multipart/form-data" class="user-edit-form">
  <div class="form-row">
    <label>Foto atual</label><br>
    <% if (dadosUsuario.foto) { %>
      <img src="/usuarios/<%= dadosUsuario.foto %>" alt="Foto atual do usuário" class="user-edit-avatar">
    <% } else { %>
      <span class="muted-text">Sem foto cadastrada</span>
    <% } %>
  </div>
  <div class="form-row">
    <label>Nome</label><br>
    <input type="text" name="nome" value="<%= dadosUsuario.nome %>" required>
  </div>
  <div class="form-row">
    <label>E-mail</label><br>
    <input type="email" name="email" value="<%= dadosUsuario.email %>" required>
  </div>
  <div class="form-row">
    <label>Telefone</label><br>
    <input type="text" name="telefone" value="<%= dadosUsuario.telefone || '' %>">
  </div>
  <div class="form-row">
    <label>Endereço</label><br>
    <input type="text" name="endereco" value="<%= dadosUsuario.endereco || '' %>">
  </div>
  <div class="form-row">
    <label>CPF</label><br>
    <input type="text" name="cpf" value="<%= dadosUsuario.cpf || '' %>">
  </div>
  <div class="form-row">
    <label>Data de nascimento</label><br>
    <input type="date" name="datanasc" value="<%= dadosUsuario.datanasc ? dadosUsuario.datanasc.toISOString().substr(0,10) : '' %>">
  </div>
  <div class="form-row">
    <label>Nova senha (opcional)</label><br>
    <input type="password" name="senha" placeholder="Deixe em branco para não alterar">
  </div>
  <div class="form-row">
    <label>Foto (opcional)</label><br>
    <input type="file" name="foto" accept="image/*">
  </div>
  <button type="submit">Salvar alterações</button>
  <a href="/usuario" class="inline-cancel">Cancelar</a>
</form>

<%- include('rodape') %>

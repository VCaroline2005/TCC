<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portal Enfermagem</title>
  <link rel="stylesheet" href="/site/css/pages.css">
</head>
<% const pageClassLocal = (typeof pageClass !== 'undefined' && pageClass) ? pageClass : ''; %>
<% const usuarioLocal = (typeof usuario !== 'undefined' && usuario) ? usuario : null; %>
<body class="public-page <%= pageClassLocal %>">
  <header class="site-header">
    <div class="site-brand">
      <img src="/site/img/logo.png" alt="Portal Enfermagem">
      <h1 class="portal-title">Portal Enfermagem</h1>
    </div>
    <nav class="site-nav">
      <% if (usuarioLocal) { %>
        <a href="/home">Home</a>
      <% } else { %>
        <a href="/">Início</a>
      <% } %>
      <a href="/procedimentos">Procedimentos</a>
      <a href="/medicamentos">Medicamentos</a>
      <a href="/terminologias">Terminologias</a>
      <a href="/quiz">Quiz</a>
      <a href="/lembretes">Lembretes</a>
      <% if (usuarioLocal) { %>
        <a href="/usuario">Minha Conta</a>
        <% if (usuarioLocal.admin) { %>
          <a href="/admin/usuarios/lst">Admin</a>
        <% } %>
      <% } else { %>
        <a href="/login">Entrar</a>
        <a href="/cadastro">Cadastre-se</a>
      <% } %>
    </nav>
    <div class="nav-controls">
      <button type="button" class="nav-btn" onclick="history.back()">Voltar</button>
      <% if (usuarioLocal) { %>
        <a class="nav-btn" href="/sair">Sair</a>
      <% } else { %>
        <a class="nav-btn" href="/login">Entrar</a>
      <% } %>
    </div>
  </header>
  <main>

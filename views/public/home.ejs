<%- include('cabecalho', { pageClass: 'page-home' }) %>

<% const usuarioLocal = (typeof usuario !== 'undefined' && usuario) ? usuario : null; %>
<% const procedimentoTotal = (typeof procedimentoCount !== 'undefined' && procedimentoCount) ? procedimentoCount : 0; %>
<% const medicamentoTotal = (typeof medicamentoCount !== 'undefined' && medicamentoCount) ? medicamentoCount : 0; %>
<% const termoTotal = (typeof termoCount !== 'undefined' && termoCount) ? termoCount : 0; %>
<% const quizTotal = (typeof quizCount !== 'undefined' && quizCount) ? quizCount : 0; %>
<% const conteudosLocal = (typeof conteudosRecentes !== 'undefined' && conteudosRecentes) ? conteudosRecentes : []; %>
<% const conteudosCount = conteudosLocal.length; %>
<% const formatDate = (data) => { try { return new Date(data).toLocaleDateString('pt-BR'); } catch (e) { return ''; } }; %>

<div class="home-shell">  <div class="home-main">
    <section class="home-panel" aria-label="Resumo inicial">

      <div class="hero" style="padding:40px;border-radius:16px;">
        <div style="max-width:700px;">
          <h2 class="hero-title" style="font-size:48px;line-height:1.1;margin-bottom:16px;">
            Tudo que você precisa para estudar
            <span class="accent">Enfermagem</span>
            em um só lugar.
          </h2>

          <p class="hero-subtitle" style="font-size:18px;max-width:600px;">
            Acesse procedimentos, medicamentos, terminologias, quizzes e materiais de estudo de forma rápida e organizada.
          </p>

          <div class="hero-actions" style="margin-top:24px;">
            <a class="btn-primary" href="/procedimentos">
              Começar agora
            </a>

            <a class="btn-secondary" href="/conteudos">
              Meus materiais
            </a>
          </div>
        </div>
      </div>

      <form
        class="searchbar"
        id="homeSearchForm"
        method="get"
        action="#"
        style="margin-top:24px;"
      >
        <div class="search-field">
          <input
            class="search-input"
            type="text"
            name="q"
            placeholder="Buscar por procedimentos, medicamentos ou terminologias..."
            autocomplete="off"
          >
        </div>

        <select class="search-select" name="scope">
          <option value="procedimentos">Procedimentos</option>
          <option value="medicamentos">Medicamentos</option>
          <option value="terminologias">Terminologias</option>
        </select>

        <button class="search-submit" type="submit">
          Buscar
        </button>
      </form>

      <div
        class="module-grid"
        style="
          margin-top:24px;
          display:grid;
          grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
          gap:20px;
        "
      >
        <a class="module-card" href="/procedimentos">
          <h3 class="module-title">Procedimentos</h3>
          <p class="module-desc">
            Passo a passo dos principais procedimentos de enfermagem.
          </p>
        </a>

        <a class="module-card" href="/medicamentos">
          <h3 class="module-title">Medicamentos</h3>
          <p class="module-desc">
            Classes, indicações, vias e diluições.
          </p>
        </a>

        <a class="module-card" href="/terminologias">
          <h3 class="module-title">Terminologias</h3>
          <p class="module-desc">
            Consulte termos técnicos e definições.
          </p>
        </a>
      </div>

   
      <div class="cta" style="margin-top:24px;">
        <strong>
          Sua plataforma completa para aprender e evoluir na Enfermagem.
        </strong>

        <a class="cta-btn" href="/usuario">
          Minha conta
        </a>
      </div>

    </section>
  </div>
<aside class="home-aside" aria-label="Painel lateral" style="display:flex;flex-direction:column;gap:20px;">

  <section class="preview">
    <div class="preview-header">
      <h3 class="preview-title">Biblioteca</h3>
    </div>

    <div style="
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:12px;
      margin-top:12px;
    ">
      <div class="preview-item" style="padding:16px;text-align:center;">
        <h4 style="margin:0;font-size:24px;"><%= medicamentoTotal %></h4>
        <p style="margin:4px 0 0;">Medicamentos</p>
      </div>

      <div class="preview-item" style="padding:16px;text-align:center;">
        <h4 style="margin:0;font-size:24px;"><%= procedimentoTotal %></h4>
        <p style="margin:4px 0 0;">Procedimentos</p>
      </div>

      <div class="preview-item" style="padding:16px;text-align:center;">
        <h4 style="margin:0;font-size:24px;"><%= termoTotal %></h4>
        <p style="margin:4px 0 0;">Termos</p>
      </div>

      <div class="preview-item" style="padding:16px;text-align:center;">
        <h4 style="margin:0;font-size:24px;"><%= quizTotal %></h4>
        <p style="margin:4px 0 0;">Quizzes</p>
      </div>
    </div>

    <div style="margin-top:16px;">
      <a class="preview-more" href="/medicamentos">Ver biblioteca</a>
    </div>
  </section>

  <section class="preview">
    <div class="preview-header">
      <h3 class="preview-title">Materiais recentes</h3>
      <span class="pill is-on"><%= conteudosCount %></span>
    </div>

    <% if (conteudosCount > 0) { %>

      <div style="
        display:flex;
        flex-direction:column;
        gap:12px;
        margin-top:12px;
      ">

        <% conteudosLocal.slice(0,5).forEach(function(c) { %>

          <div style="
            padding:14px;
            border:1px solid #e5e7eb;
            border-radius:12px;
            background:#fff;
          ">
            <h5 style="
              margin:0 0 6px;
              font-size:14px;
              font-weight:600;
            ">
              <%= c.titulo %>
            </h5>

            <p style="
              margin:0;
              color:#6b7280;
              font-size:12px;
            ">
              <%= formatDate(c.criadoEm) %>
              <% if (c.categoria) { %>
                • <%= c.categoria %>
              <% } %>
            </p>
          </div>

        <% }) %>

      </div>

    <% } else { %>

      <div class="preview-item" style="margin-top:12px;">
        <div>
          <h5>Nenhum material encontrado</h5>
          <p>Envie seus PDFs para começar.</p>
        </div>
      </div>

    <% } %>

    <div style="margin-top:16px;">
      <a class="preview-more" href="/conteudos">Ver todos</a>
    </div>
  </section>

  <section class="preview">
    <div class="preview-header">
      <h3 class="preview-title">Minha conta</h3>
    </div>

    <div class="account-box" style="margin-top:12px;">
      <div class="avatar">
        <%= (usuarioLocal && usuarioLocal.nome)
          ? usuarioLocal.nome.trim().slice(0,1).toUpperCase()
          : 'A' %>
      </div>

      <div>
        <p class="account-name">
          <%= (usuarioLocal && usuarioLocal.nome)
            ? usuarioLocal.nome
            : 'Aluno(a)' %>
        </p>

        <p class="account-email">
          <%= (usuarioLocal && usuarioLocal.email)
            ? usuarioLocal.email
            : '' %>
        </p>
      </div>
    </div>

    <div class="account-actions" style="
      margin-top:16px;
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    ">
      <a class="tiny-link primary" href="/conteudos">Materiais</a>
      <a class="tiny-link" href="/quiz">Quiz</a>
      <a class="tiny-link" href="/usuario">Perfil</a>
    </div>
  </section>

</aside>
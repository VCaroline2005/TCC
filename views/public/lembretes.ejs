<%- include('cabecalho') %>
<style>
  .lembrete-form {
    margin-bottom: 12px;
  }
  .lembrete-btn {
    padding: 10px 18px;
    background: #a51b0b;
    color: #fff;
    border: 1px solid #a51b0b;
    border-radius: 999px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .lembrete-btn:hover {
    background: #7a1408;
    transform: translateY(-1px);
    box-shadow: 0 10px 18px rgba(122, 20, 8, 0.2);
  }
  .lembrete-cancel {
    margin-left: 8px;
    text-decoration: none;
    font-weight: 700;
    color: #7a1408;
  }
  .lembrete-actions {
    display: inline-flex;
    gap: 8px;
    margin-left: 6px;
  }
  .lembrete-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid #a51b0b;
    font-weight: 700;
    text-decoration: none;
    color: #a51b0b;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .lembrete-link:hover {
    background: #a51b0b;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 8px 16px rgba(122, 20, 8, 0.18);
  }
  .lembrete-link.danger {
    border-color: #7a1408;
    color: #7a1408;
  }
  .lembrete-link.danger:hover {
    background: #7a1408;
    color: #fff;
  }
  .lembrete-alert {
    margin: 12px 0;
    padding: 10px 12px;
    border-radius: 10px;
    background: #fff7ed;
    border: 1px solid #f59e0b;
    color: #92400e;
    font-weight: 600;
  }
  .lembrete-badge {
    display: inline-flex;
    align-items: center;
    margin-left: 6px;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    border: 1px solid transparent;
  }
  .lembrete-badge.warn {
    background: #fef3c7;
    color: #92400e;
    border-color: #f59e0b;
  }
  .lembrete-badge.danger {
    background: #fee2e2;
    color: #b91c1c;
    border-color: #fca5a5;
  }
</style>
<h2>Lembretes</h2>
<% const agora = new Date(); %>
<% const limite = new Date(); limite.setDate(limite.getDate() + 3); %>
<% const lembretesProximos = Lembretes.filter(function(l){ return l.vencimento && l.vencimento <= limite; }); %>
<% if (lembretesProximos.length) { %>
  <div class="lembrete-alert">
    Você tem <%= lembretesProximos.length %> lembrete(s) vencendo em até 3 dias.
  </div>
<% } %>
<% const editandoLocal = (typeof editando !== 'undefined' && editando); %>
<% const lembreteEdicaoLocal = (typeof LembreteEdicao !== 'undefined' && LembreteEdicao) ? LembreteEdicao : null; %>
<% if (typeof erro !== 'undefined' && erro === 'conteudo') { %>
  <p style="color:#b91c1c;">Digite o conteúdo do lembrete antes de adicionar.</p>
<% } %>
<% if (typeof erro !== 'undefined' && erro === 'salvar') { %>
  <p style="color:#b91c1c;">Não foi possível salvar o lembrete. Tente novamente.</p>
<% } %>
<% if (editandoLocal && lembreteEdicaoLocal) { %>
  <form method="post" action="/lembretes/edt/<%= lembreteEdicaoLocal._id %>" class="lembrete-form">
    <textarea name="conteudo" rows="2" cols="50" placeholder="O que lembrar?" required><%= lembreteEdicaoLocal.conteudo %></textarea><br>
    <label>Data de vencimento: <input type="date" name="vencimento" value="<%= lembreteEdicaoLocal.vencimento ? lembreteEdicaoLocal.vencimento.toISOString().substr(0,10) : '' %>"></label><br>
    <input type="submit" value="Salvar" class="lembrete-btn">
    <a href="/lembretes" class="lembrete-cancel">Cancelar</a>
  </form>
<% } else { %>
  <form method="post" action="/lembretes" class="lembrete-form">
    <textarea name="conteudo" rows="2" cols="50" placeholder="O que lembrar?" required></textarea><br>
    <label>Data de vencimento: <input type="date" name="vencimento"></label><br>
    <input type="submit" value="Adicionar" class="lembrete-btn">
  </form>
<% } %>
<ul>
  <% Lembretes.forEach(function(l){ %>
    <% const vencido = l.vencimento && l.vencimento <= agora; %>
    <% const vencendo = l.vencimento && l.vencimento > agora && l.vencimento <= limite; %>
    <li>
      <strong><%=l.conteudo%></strong> até <%= l.vencimento ? l.vencimento.toISOString().substr(0,10) : 'sem data' %>
      <% if (vencido) { %>
        <span class="lembrete-badge danger">Vencido</span>
      <% } else if (vencendo) { %>
        <span class="lembrete-badge warn">Vencendo</span>
      <% } %>
      <span class="lembrete-actions">
        <a class="lembrete-link" href="/lembretes/edt/<%= l._id %>">Editar</a>
        <a class="lembrete-link danger" href="/lembretes/del/<%= l._id %>" onclick="return confirm('Tem certeza que deseja excluir este lembrete?')">Excluir</a>
      </span>
    </li>
  <% }) %>
</ul>
<%- include('rodape') %>

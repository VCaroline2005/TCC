<%- include('cabecalho', { pageClass: 'page-procedimentos' }) %>
<% const pesquisaAtual = (typeof pesquisar !== 'undefined' && pesquisar) ? pesquisar : ''; %>
<%
  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatProcedimento(text) {
    if (!text) return '';
    const lines = String(text).replace(/\r\n/g, '\n').split('\n');
    let html = '';
    let inOl = false;
    let inUl = false;
    let openLi = false;

    function closeListItem() {
      if (openLi) {
        if (inOl) {
          html += '</div></li>';
        } else {
          html += '</li>';
        }
        openLi = false;
      }
    }

    function closeLists() {
      closeListItem();
      if (inOl) {
        html += '</ol>';
        inOl = false;
      }
      if (inUl) {
        html += '</ul>';
        inUl = false;
      }
    }

    lines.forEach((line) => {
      const trimmed = line.trim();
      if (!trimmed) {
        closeLists();
        html += '<div class="proc-gap"></div>';
        return;
      }

      const isAllCaps = /^[A-Z0-9ÁÉÍÓÚÂÊÔÃÕÇ\s().-]{6,}$/.test(trimmed);
      const isHeading = /:$/.test(trimmed) || isAllCaps;
      if (isHeading) {
        closeLists();
        const clean = trimmed.replace(/:$/, '');
        html += `<h4 class="proc-section-title">${escapeHtml(clean)}</h4>`;
        const headingLower = clean.toLowerCase();
        if (headingLower.includes('ação de enfermagem e justificativa') || headingLower.includes('acao de enfermagem e justificativa')) {
          html += '<div class="proc-table-head"><span>Ação</span><span>Justificativa</span></div>';
        }
        return;
      }

      const orderedMatch = trimmed.match(/^(\d+)\.\s+(.*)$/);
      if (orderedMatch) {
        if (!inOl) {
          closeLists();
          html += '<ol class="proc-steps-list">';
          inOl = true;
        }
        closeListItem();
        html += `<li class="proc-step-row"><div class="proc-step-col"><div class="proc-step">${escapeHtml(orderedMatch[2])}</div></div><div class="proc-just-col">`;
        openLi = true;
        return;
      }

      const bulletMatch = trimmed.match(/^[-•]\s+(.*)$/);
      if (bulletMatch) {
        if (!inUl) {
          closeLists();
          html += '<ul class="proc-bullets">';
          inUl = true;
        }
        closeListItem();
        html += `<li>${escapeHtml(bulletMatch[1])}</li>`;
        return;
      }

      const justificativaMatch = /^Justificativa:/i.test(trimmed);
      if (inOl && openLi && justificativaMatch) {
        const justificativaText = trimmed.replace(/^Justificativa:\s*/i, '');
        html += `<div class="proc-justificativa"><span class="proc-just-label">Justificativa</span>${escapeHtml(justificativaText)}</div>`;
        return;
      }

      closeLists();
      html += `<p class="proc-paragraph">${escapeHtml(trimmed)}</p>`;
    });

    closeLists();
    return html;
  }
%>

<section class="proc-hero">
  <div>
    <p class="proc-eyebrow">Biblioteca clínica</p>
    <h2 class="proc-title">Procedimentos</h2>
    <p class="proc-subtitle">Encontre protocolos, descrições e passo a passo em um só lugar.</p>
  </div>
  <form method="get" action="/procedimentos" class="proc-search">
    <input
      type="text"
      name="pesquisar"
      placeholder="Pesquisar por nome, descrição ou categoria"
      value="<%= pesquisaAtual %>"
    >
    <button type="submit">Pesquisar</button>
  </form>
</section>

<ul class="proc-list">
  <% Procedimentos.forEach(function(p, idx){ %>
    <li class="proc-card">
      <button
        type="button"
        class="proc-toggle"
        data-target="proc-<%= idx %>"
        aria-expanded="false"
        aria-controls="proc-<%= idx %>"
      >
        <span class="proc-meta">
          <span><%= p.nome %></span>
          <span class="proc-category"><%= p.categoria %></span>
        </span>
        <span class="proc-arrow">▾</span>
      </button>
      <div id="proc-<%= idx %>" class="proc-details">
        <div class="proc-doc">
          <%- formatProcedimento(p.descricao) %>
        </div>
        <% if (p.passos && p.passos.length) { %>
          <div class="proc-steps">
            <strong>Passo a passo:</strong>
            <ol>
              <% p.passos.forEach(function(passo){ %>
                <li><%= passo %></li>
              <% }) %>
            </ol>
          </div>
        <% } %>
        <% if (p.fotos && p.fotos.length) { %>
          <div class="proc-photos">
            <% p.fotos.forEach(function(foto){ %>
              <img src="/fotos/<%= foto %>" alt="Foto do procedimento">
            <% }) %>
          </div>
        <% } %>
      </div>
    </li>
  <% }) %>
</ul>
<script>
  document.querySelectorAll('.proc-toggle').forEach(function(btn){
    btn.addEventListener('click', function(){
      const id = btn.getAttribute('data-target');
      const el = document.getElementById(id);
      if (!el) return;
      const isOpen = el.classList.toggle('is-open');
      btn.classList.toggle('is-open', isOpen);
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  });
</script>
<%- include('rodape') %>

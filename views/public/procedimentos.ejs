<%- include('cabecalho', { pageClass: 'page-procedimentos' }) %>
<% const pesquisaAtual = (typeof pesquisar !== 'undefined' && pesquisar) ? pesquisar : ''; %>
<%
  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatProcedimento(text) {
    if (!text) return '';
    const lines = String(text).replace(/\r\n/g, '\n').split('\n');
    let html = '';
    let inOl = false;
    let inUl = false;
    let openLi = false;

    function closeListItem() {
      if (openLi) {
        if (inOl) {
          html += '</div></li>';
        } else {
          html += '</li>';
        }
        openLi = false;
      }
    }

    function closeLists() {
      closeListItem();
      if (inOl) {
        html += '</ol>';
        inOl = false;
      }
      if (inUl) {
        html += '</ul>';
        inUl = false;
      }
    }

    lines.forEach((line) => {
      const trimmed = line.trim();
      if (!trimmed) {
        closeLists();
        html += '<div class="proc-gap"></div>';
        return;
      }

      const isAllCaps = /^[A-Z0-9ÁÉÍÓÚÂÊÔÃÕÇ\s().-]{6,}$/.test(trimmed);
      const isHeading = /:$/.test(trimmed) || isAllCaps;
      if (isHeading) {
        closeLists();
        const clean = trimmed.replace(/:$/, '');
        html += `<h4 class="proc-section-title">${escapeHtml(clean)}</h4>`;
        const headingLower = clean.toLowerCase();
        if (headingLower.includes('ação de enfermagem e justificativa') || headingLower.includes('acao de enfermagem e justificativa')) {
          html += '<div class="proc-table-head"><span>Ação</span><span>Justificativa</span></div>';
        }
        return;
      }

      const orderedMatch = trimmed.match(/^(\d+)\.\s+(.*)$/);
      if (orderedMatch) {
        if (!inOl) {
          closeLists();
          html += '<ol class="proc-steps-list">';
          inOl = true;
        }
        closeListItem();
        html += `<li class="proc-step-row" data-step="${escapeHtml(orderedMatch[1])}"><div class="proc-step-col"><div class="proc-step">${escapeHtml(orderedMatch[2])}</div></div><div class="proc-just-col">`;
        openLi = true;
        return;
      }

      const bulletMatch = trimmed.match(/^[-•]\s+(.*)$/);
      if (bulletMatch) {
        if (!inUl) {
          closeLists();
          html += '<ul class="proc-bullets">';
          inUl = true;
        }
        closeListItem();
        html += `<li>${escapeHtml(bulletMatch[1])}</li>`;
        return;
      }

      const justificativaMatch = /^Justificativa:/i.test(trimmed);
      if (inOl && openLi && justificativaMatch) {
        const justificativaText = trimmed.replace(/^Justificativa:\s*/i, '');
        html += `<div class="proc-justificativa"><span class="proc-just-label">Justificativa</span>${escapeHtml(justificativaText)}</div>`;
        return;
      }

      closeLists();
      html += `<p class="proc-paragraph">${escapeHtml(trimmed)}</p>`;
    });

    closeLists();
    return html;
  }
%>

<div class="proc-shell">
  <section class="proc-hero">
    <div>
     
      <h2 class="proc-title">Procedimentos</h2>
      <p class="proc-subtitle">Encontre protocolos, descrições e passo a passo em um só lugar.</p>
    </div>
    <form method="get" action="/procedimentos" class="proc-search" aria-label="Pesquisar procedimentos">
      <input
        type="text"
        name="pesquisar"
        placeholder="Pesquisar por nome, descrição ou categoria..."
        value="<%= pesquisaAtual %>"
        autocomplete="off"
      >
      <button type="submit" aria-label="Pesquisar">
        <span aria-hidden="true">⌕</span>
        Pesquisar
      </button>
    </form>
  </section>

  <ul class="proc-list">
    <% Procedimentos.forEach(function(p, idx){ %>
      <li class="proc-card">
        <button
          type="button"
          class="proc-toggle"
          data-target="proc-<%= idx %>"
          aria-expanded="false"
          aria-controls="proc-<%= idx %>"
        >
          <span class="proc-meta">
            <span class="proc-ic" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 3h12v18H6V3Z" stroke="currentColor" stroke-width="2"/>
                <path d="M9 7h6M9 11h6M9 15h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="proc-name"><%= p.nome %></span>
            <span class="proc-category"><%= p.categoria %></span>
          </span>
          <span class="proc-arrow" aria-hidden="true">▾</span>
        </button>
        <div id="proc-<%= idx %>" class="proc-details">
          <div class="proc-details-grid">
            

            <aside class="proc-block proc-side" aria-label="Pontos importantes">
              <h3 class="proc-block-title"><span aria-hidden="true"></span>Protocolo de Segurança</h3>
              <ul>
              
                <li>Confirmar a identificação correta do paciente.</li>
                <li>Explicar o procedimento ao paciente e esclarecer dúvidas.</li>
                <li>Verificar indicações, contraindicações e riscos.</li>
                <li>Realizar higienização das mãos antes e após o procedimento.</li>
                <li>Utilizar EPIs conforme necessidade.</li>
                <li>Garantir ambiente, materiais e equipamentos adequados.</li>
                <li>Manter técnica asséptica quando indicada.</li>
                <li>Monitorar o paciente durante e após o procedimento.</li>
                <li>Registrar o procedimento e possíveis intercorrências no prontuário.</li>
                <li>Seguir os protocolos institucionais e normas de segurança do paciente.</li>
              </ul>
              
            </aside>

            <section class="proc-block" style="grid-column: 1 / -1;" aria-label="Passo a passo">
              <h3 class="proc-block-title"><span aria-hidden="true"></span>Passo a passo</h3>
              <% if (p.passos && p.passos.length) { %>
                <ol class="proc-steps-list">
                  <% p.passos.forEach(function(passo, passoIdx){ %>
                    <li data-step="<%= passoIdx + 1 %>"><%= passo %></li>
                  <% }) %>
                </ol>
              <% } else { %>
                <p class="proc-paragraph">Clique no POP abaixo para Download.</p>
              <% } %>
              <% if (p.popPdfNome) { %>
                <div class="proc-pdf">
                  <a class="proc-pdf-link" href="/uploads/pops/<%= p.popPdfNome %>" target="_blank" rel="noopener">Abrir POP (PDF)</a>
                  <% if (p.popPdfOriginal) { %>
                    <span class="proc-pdf-name muted-text"><%= p.popPdfOriginal %></span>
                  <% } %>
                </div>
              <% } %>
            </section>
          </div>
        </div>
      </li>
    <% }) %>
  </ul>

</div>
<script>
  document.querySelectorAll('.proc-toggle').forEach(function(btn){
    btn.addEventListener('click', function(){
      const id = btn.getAttribute('data-target');
      const el = document.getElementById(id);
      if (!el) return;
      const isOpen = el.classList.toggle('is-open');
      btn.classList.toggle('is-open', isOpen);
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  });
</script>
<%- include('rodape') %>

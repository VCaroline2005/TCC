<%- include('cabecalho', { pageClass: 'page-quiz' }) %>

<div class="quiz-page">
  <section class="proc-hero">
    <div class="quiz-hero-text">
      <p class="proc-eyebrow">Biblioteca clínica</p>
      <h2 class="proc-title">Quiz</h2>
      <p class="proc-subtitle">Gere quizzes automaticamente a partir dos seus materiais ou responda as questões já criadas.</p>
    </div>

    <div class="quiz-upload-panel">
      <div id="upload" class="upload-box">
        <h3>Gerar quiz a partir de PDF</h3>
        <p class="upload-note">Envie um PDF para criar um conjunto de questões automaticamente com base no conteúdo do arquivo.</p>
        <form method="post" action="/quiz/upload" enctype="multipart/form-data">
          <input type="file" class="input" name="arquivo" accept="application/pdf">
          <div class="upload-actions">
            <button class="btn">Gerar quiz a partir do PDF</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="quiz-list card">
    <div class="quiz-list-header">
      <div>
        <h2>Meus quizzes</h2>
        <p>Visualize, filtre e responda aos quizzes que você já criou.</p>
      </div>
      <% if (!perguntasAdmin.length && !perguntasIA.length) { %>
        <a class="btn btn-secondary" href="#upload">Gerar meu primeiro quiz</a>
      <% } %>
    </div>

    <form class="quiz-filter-bar" method="get" action="/quiz">
      <div class="quiz-filter-field">
        <label for="sistema">Filtrar por sistema</label>
        <select name="sistema" id="sistema" class="input">
          <option value="">Todos os sistemas</option>
          <% sistemas.forEach(function(s){ %>
            <option value="<%= s %>" <%= sistemaSelecionado === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <button class="btn">Aplicar filtros</button>
    </form>

    <% if (perguntasAdmin.length) { %>
      <form method="post" action="/quiz/responder" class="quiz-form">
        <% perguntasAdmin.forEach(function(p, index){ %>
          <div class="quiz-card">
            <p class="quiz-question"><%= index + 1 %>. <%= p.pergunta %></p>
            <div class="options-grid">
              <% p.opcoes.forEach(function(opt, optIndex){ %>
                <label class="quiz-option">
                  <input type="radio" name="respostas[<%= p._id %>]" value="<%= optIndex %>">
                  <span><%= opt %></span>
                </label>
              <% }) %>
            </div>
          </div>
        <% }) %>

        <div class="quiz-actions">
          <button class="btn">Enviar respostas</button>
        </div>
      </form>
    <% } else { %>
      <div class="quiz-empty-state">
        <p>Nenhuma pergunta encontrada.</p>
      </div>
    <% } %>
  </section>

  <section class="quiz-ia card">
    <div class="quiz-list-header">
      <div>
        <h2>Quiz gerado por PDF</h2>
        <p>Aqui ficam os quizzes criados automaticamente a partir de PDFs enviados.</p>
      </div>
    </div>

    <% if (perguntasIA.length) { %>
      <% perguntasIA.forEach(function(p, index){ %>
        <div class="quiz-card quiz-card-ia">
          <p class="quiz-question"><%= index + 1 %>. <%= p.pergunta %></p>
          <div class="options-grid">
            <% p.opcoes.forEach(function(opt){ %>
              <div class="quiz-option disabled">
                <span><%= opt %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="quiz-empty-state">
        <p>Nenhum quiz gerado ainda</p>
      </div>
    <% } %>
  </section>
</div>

<%- include('rodape') %>
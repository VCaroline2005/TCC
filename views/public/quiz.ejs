<%- include('cabecalho', { pageClass: 'page-quiz' }) %>
<% const perguntasAdminLocal = (typeof perguntasAdmin !== 'undefined' && perguntasAdmin) ? perguntasAdmin : []; %>
<% const perguntasIALocal = (typeof perguntasIA !== 'undefined' && perguntasIA) ? perguntasIA : []; %>
<% const sistemasLocal = (typeof sistemas !== 'undefined' && sistemas) ? sistemas : []; %>
<% const sistemaSelecionadoLocal = (typeof sistemaSelecionado !== 'undefined' && sistemaSelecionado) ? sistemaSelecionado : ''; %>

<div class="quiz-page">
  <section class="page-hero">
    <div>
      
      <h2>Quiz</h2>
      <p>Gere quizzes automaticamente a partir dos seus materiais ou responda as questões já criadas.</p>
    </div>

    <div class="page-hero-stat">
      <strong><%= perguntasAdminLocal.length + perguntasIALocal.length %></strong>
      <span>questões</span>
    </div>
  </section>



  <section class="app-card quiz-upload-panel">
      <div id="upload" class="upload-box">
        <h3>Gerar quiz a partir de PDF</h3>
        <p class="upload-note">Envie um PDF para criar um conjunto de questões automaticamente com base no conteúdo do arquivo.</p>
        <form method="post" action="/quiz/upload" enctype="multipart/form-data">
          <input type="file" class="input" name="arquivo" accept="application/pdf">
          <div class="upload-actions">
            <button class="btn">Gerar quiz a partir do PDF</button>
          </div>
        </form>
      </div>
  </section>

  <section class="app-card quiz-list">
    <div class="quiz-list-header">
      <div>
        <h2>Meus quizzes</h2>
        <p>Visualize, filtre e responda aos quizzes que você já criou.</p>
      </div>
      <% if (!perguntasAdminLocal.length && !perguntasIALocal.length) { %>
        <a class="btn btn-secondary" href="#upload">Gerar meu primeiro quiz</a>
      <% } %>
    </div>

    <form class="quiz-filter-bar" method="get" action="/quiz">
      <div class="quiz-filter-field">
        <label for="sistema">Filtrar por sistema</label>
        <select name="sistema" id="sistema" class="input">
          <option value="">Todos os sistemas</option>
          <% sistemasLocal.forEach(function(s){ %>
            <option value="<%= s %>" <%= sistemaSelecionadoLocal === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
      <button class="btn">Aplicar filtros</button>
    </form>

    <% if (perguntasAdminLocal.length || perguntasIALocal.length) { %>
      <form method="post" action="/quiz/responder" class="quiz-form">
        <% perguntasAdminLocal.forEach(function(p, index){ %>
          <div class="app-card quiz-card">
            <p class="quiz-question"><%= index + 1 %>. <%= p.pergunta %></p>
            <div class="options-grid">
              <% p.opcoes.forEach(function(opt, optIndex){ %>
                <label class="quiz-option">
                  <input type="radio" name="respostas[<%= p._id %>]" value="<%= optIndex %>">
                  <span><%= opt %></span>
                </label>
              <% }) %>
            </div>
          </div>
        <% }) %>

        <% perguntasIALocal.forEach(function(p, index){ %>
          <div class="app-card quiz-card quiz-card-ia">
            <p class="quiz-question"><%= perguntasAdminLocal.length + index + 1 %>. <%= p.pergunta %></p>
            <div class="options-grid">
              <% p.opcoes.forEach(function(opt, optIndex){ %>
                <label class="quiz-option">
                  <input type="radio" name="respostas[<%= p._id %>]" value="<%= optIndex %>">
                  <span><%= opt %></span>
                </label>
              <% }) %>
            </div>
          </div>
        <% }) %>

        <div class="quiz-actions">
          <button class="btn">Enviar respostas</button>
        </div>
      </form>
    <% } else { %>
      <div class="app-empty">Nenhuma pergunta encontrada.</div>
    <% } %>
  </section>

  <section class="app-card quiz-ia">
    <div class="quiz-list-header">
      <div>
        <h2>Quiz gerado por PDF</h2>
        <p>Aqui ficam os quizzes criados automaticamente a partir de PDFs enviados.</p>
      </div>
    </div>

    <% if (!perguntasIALocal.length) { %>
      <div class="app-empty">Nenhum quiz gerado ainda.</div>
    <% } else { %>
      <div class="app-empty">Os quizzes gerados por PDF agora aparecem acima, junto com as respostas.</div>
    <% } %>
  </section>
</div>

<%- include('rodape') %>

<%- include('cabecalho', { pageClass: 'page-quiz' }) %>

<% const perguntasLista = (typeof Perguntas !== 'undefined' && Perguntas) ? Perguntas : []; %>
<% const sistemasLista = (typeof sistemas !== 'undefined' && sistemas) ? sistemas : []; %>
<% const sistemaAtual = (typeof sistemaSelecionado !== 'undefined' && sistemaSelecionado) ? sistemaSelecionado : ''; %>
<% const statusUpload = (typeof uploadStatus !== 'undefined' && uploadStatus) ? uploadStatus : ''; %>
<% const totalNovas = (typeof uploadCount !== 'undefined' && uploadCount) ? uploadCount : 0; %>
<% const aiOk = (typeof aiEnabled !== 'undefined') ? aiEnabled : false; %>
<% const mockModeEnabled = (typeof mockMode !== 'undefined') ? mockMode : false; %>

<h2>Quiz por sistema</h2>

<section class="upload-box" aria-label="Envio de PDF para gerar quiz">
  <h3>Gerar quiz a partir de PDF</h3>
  <p class="upload-note">Envie um PDF para gerar questões automaticamente.</p>
  <form method="post" action="/quiz/upload" enctype="multipart/form-data">
    <input type="file" name="arquivo" accept=".pdf,application/pdf" required <%= aiOk ? '' : 'disabled' %>>
    <div class="upload-actions">
      <button type="submit" <%= aiOk ? '' : 'disabled' %>>Enviar PDF</button>
    </div>
  </form>
  <% if (!aiOk) { %>
    <div class="upload-msg error">Configuração necessária: defina a variável GEMINI_API_KEY no servidor.</div>
  <% } else if (mockModeEnabled) { %>
    <div class="upload-msg success">Modo teste ativo: as perguntas serão geradas localmente (sem IA).</div>
  <% } else if (statusUpload === 'ok') { %>
    <div class="upload-msg success">Quiz criado com sucesso. <%= totalNovas %> questão(ões) adicionada(s).</div>
  <% } else if (statusUpload === 'pdf-vazio') { %>
    <div class="upload-msg error">O PDF enviado não contém texto suficiente para gerar perguntas.</div>
  <% } else if (statusUpload === 'gerar') { %>
    <div class="upload-msg error">Não foi possível gerar perguntas com este PDF.</div>
  <% } else if (statusUpload === 'indisponivel') { %>
    <div class="upload-msg error">A IA está temporariamente indisponível (alta demanda). Tente novamente em alguns minutos.</div>
  <% } else if (statusUpload === 'api') { %>
    <div class="upload-msg error">Falha ao gerar com IA. Tente novamente mais tarde.</div>
  <% } else if (statusUpload === 'sem-chave') { %>
    <div class="upload-msg error">A chave da API não está configurada no servidor.</div>
  <% } else if (statusUpload === 'erro') { %>
    <div class="upload-msg error">Não foi possível enviar o PDF. Tente novamente.</div>
  <% } %>
</section>

<form method="get" action="/quiz" class="filter-form quiz-filter-form">
  <label for="sistema" class="filter-label">Filtrar por sistema</label>
  <select name="sistema" id="sistema" class="filter-select filter-select-compact">
    <option value="">Todos</option>
    <% if (sistemasLista.length) { %>
      <% sistemasLista.forEach(function(s){ %>
        <option value="<%= s %>" <%= (sistemaAtual === s) ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    <% } %>
  </select>
  <button type="submit" class="filter-btn">Aplicar</button>
</form>

<% if(perguntasLista.length){ %>
  <form method="post" action="/quiz/responder">
    <%
      const grupos = {};
      perguntasLista.forEach(function(p){
        const sistema = (p.categoria && p.categoria.trim()) ? p.categoria.trim() : 'Sem sistema';
        if (!grupos[sistema]) grupos[sistema] = [];
        grupos[sistema].push(p);
      });
      const sistemasOrdenados = Object.keys(grupos).sort(function(a,b){ return a.localeCompare(b, 'pt-BR'); });
      let contador = 1;
    %>
    <% sistemasOrdenados.forEach(function(sistema){ %>
      <section class="quiz-group">
        <h3><%= sistema %></h3>
        <% grupos[sistema].forEach(function(p){ %>
          <div class="quiz-card">
            <p class="quiz-question"><%= contador %>. <%= p.pergunta %></p>
            <input type="hidden" name="perguntas[]" value="<%= p._id %>">
            <% if (p.opcoes && p.opcoes.length) { %>
              <% p.opcoes.forEach(function(opt, optIdx){ %>
                <label class="quiz-option">
                  <input type="radio" name="respostas[<%= p._id %>]" value="<%= optIdx %>" <%= optIdx === 0 ? 'required' : '' %>>
                  <%= opt %>
                </label>
              <% }) %>
            <% } else { %>
              <p>Sem opções cadastradas para esta questão.</p>
            <% } %>
          </div>
          <% contador += 1; %>
        <% }) %>
      </section>
    <% }) %>

    <div class="quiz-actions">
      <button type="submit">Enviar respostas</button>
    </div>
  </form>
<% } else { %>
  <p>Não há questões cadastradas ainda.</p>
<% } %>
<%- include('rodape') %>

<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Portal Enfermagem</title>
  <link rel="stylesheet" href="/site/css/pages.css">
</head>
<body class="landing-page">
  <% const usuarioLocal = (typeof usuario !== 'undefined' && usuario) ? usuario : null; %>

  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/">
        <img src="/site/img/logo.png" alt="Portal Enfermagem">
      </a>

      <nav class="auth">
        <% if (usuarioLocal) { %>
          <a href="/usuario">Minha Conta</a>
          <a href="/sair">Sair</a>
        <% } else { %>
          <a href="/login">Entrar</a>
          <a href="/cadastro">Cadastre-se</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="landing-main">
    <section class="landing-hero">
      <div class="hero-copy">
        <span class="hero-eyebrow">Portal Enfermagem</span>
        <h1>Seu apoio rápido na prática de enfermagem</h1>
        <p>Conteúdos, protocolos, medicamentos e terminologias reunidos em um só lugar para estudar e consultar com agilidade.</p>
        <div class="hero-actions">
          <% if (usuarioLocal) { %>
            <a class="hero-cta" href="/usuario">Abrir minha conta</a>
            <a class="hero-secondary" href="/procedimentos">Ver procedimentos</a>
          <% } else { %>
            <a class="hero-cta" href="/login">Entrar</a>
            <a class="hero-secondary" href="/cadastro">Cadastre-se grátis</a>
          <% } %>
        </div>
      </div>

      <div class="hero-visual">
        <img src="/site/img/hero-illustration.svg" alt="Imagem de enfermagem">
      </div>
    </section>

    <% if (!usuarioLocal) { %>
      <section class="landing-grid" aria-label="Prévia de conteúdos">
        <div class="preview-card">
          <img src="/site/img/protocolo.png" alt="Prévia de procedimentos">
          <strong>Protocolos essenciais</strong>
          <p>Encontre os principais procedimentos em poucos cliques.</p>
        </div>
        <div class="preview-card">
          <img src="/site/img/med.png" alt="Prévia de medicamentos">
          <strong>Medicamentos organizados</strong>
          <p>Consulte classes e bulas em um único lugar.</p>
        </div>
        <div class="preview-card">
          <img src="/site/img/termo.png" alt="Prévia de terminologias">
          <strong>Terminologias rápidas</strong>
          <p>Revisão de termos e definições para estudo e prática.</p>
        </div>
      </section>
    <% } else { %>
      <section class="landing-grid" aria-label="Módulos rápidos">
        <a class="module-card" href="/procedimentos">
          <img src="/site/img/protocolo.png" alt="Procedimentos">
          <span>Procedimentos</span>
        </a>
        <a class="module-card" href="/medicamentos">
          <img src="/site/img/med.png" alt="Medicamentos">
          <span>Medicamentos</span>
        </a>
        <a class="module-card" href="/terminologias">
          <img src="/site/img/termo.png" alt="Terminologias">
          <span>Terminologias</span>
        </a>
        <a class="module-card" href="/quiz">
          <img src="/site/img/quiz.png" alt="Quiz">
          <span>Quiz</span>
        </a>
        <a class="module-card" href="/conteudos">
          <img src="/site/img/procedimento.png" alt="Conteúdos">
          <span>Conteúdos</span>
        </a>
      </section>
    <% } %>

    <footer class="landing-footer">Portal Enfermagem</footer>
  </main>
</body>
</html>

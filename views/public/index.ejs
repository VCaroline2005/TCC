<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Portal Enfermagem</title>
  <link rel="stylesheet" href="/site/css/pages.css">
</head>
<body class="landing-page">
  <% const usuarioLocal = (typeof usuario !== 'undefined' && usuario) ? usuario : null; %>

  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/">
        <img src="/site/img/logo.png" alt="Portal Enfermagem">
      </a>

      <nav class="topbar-nav" aria-label="Menu">
        <a class="topbar-link is-active" href="/">Início</a>
        <a class="topbar-link" href="#sobre">Sobre</a>
        <a class="topbar-link" href="#contato">Contato</a>
      </nav>

      <div class="topbar-actions" aria-label="Ações">
        <button type="button" class="topbar-btn" onclick="history.back()">Voltar</button>
        <% if (usuarioLocal) { %>
          <a class="topbar-btn topbar-btn--primary" href="/home">Minha conta</a>
        <% } else { %>
          <a class="topbar-btn topbar-btn--primary" href="/login">Entrar</a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="landing-main">
    <section class="landing-hero">
      <div class="hero-copy">
        <span class="hero-eyebrow">Conhecimento que salva vidas</span>
        <h1>Seu apoio rápido na prática de <span class="hero-accent">enfermagem</span></h1>
        <p>Acesse protocolos, medicamentos, terminologias e quizzes para estudar, revisar e aplicar com mais segurança no dia a dia.</p>
        <div class="hero-actions">
          <% if (usuarioLocal) { %>
            <a class="hero-cta" href="/home">Entrar e acessar tudo</a>
            <a class="hero-secondary" href="/procedimentos">Ver protocolos</a>
          <% } else { %>
            <a class="hero-cta" href="/login">Entrar e acessar tudo</a>
            <a class="hero-secondary" href="/cadastro">Criar conta grátis</a>
          <% } %>
        </div>
      </div>

    </section>

    <section class="landing-grid" aria-label="Acessos rápidos">
      <a class="feature-card" href="/procedimentos">
        <div class="feature-media">
          <img src="/site/img/protocolo.png" alt="Protocolos">
        </div>
        <div class="feature-body">
          <h3>Protocolos essenciais<br><span class="feature-accent">em poucos cliques</span></h3>
          <p>Acesse protocolos atualizados para guiar suas condutas com segurança.</p>
          <span class="feature-link">Acessar protocolos</span>
        </div>
      </a>

      <a class="feature-card" href="/medicamentos">
        <div class="feature-media">
          <img src="/site/img/med.png" alt="Medicamentos">
        </div>
        <div class="feature-body">
          <h3>Medicamentos<br><span class="feature-accent">organizados por classe</span></h3>
          <p>Consulte medicamentos, vias de administração e diluições de forma rápida e prática.</p>
          <span class="feature-link">Ver medicamentos</span>
        </div>
      </a>

      <a class="feature-card" href="/terminologias">
        <div class="feature-media">
          <img src="/site/img/termo.png" alt="Termos e definições">
        </div>
        <div class="feature-body">
          <h3>Termos e definições<br><span class="feature-accent">para revisão rápida</span></h3>
          <p>Glossário completo de terminologias para revisar e fixar o conhecimento.</p>
          <span class="feature-link">Consultar termos</span>
        </div>
      </a>
    </section>

    <section class="landing-metrics" aria-label="Diferenciais">
      <div class="metric">
        <strong>Conteúdo confiável</strong>
        <span>Fontes e materiais selecionados por profissionais.</span>
      </div>
      <div class="metric">
        <strong>Acesso rápido</strong>
        <span>Informações essenciais em segundos.</span>
      </div>
      <div class="metric">
        <strong>Estude no seu ritmo</strong>
        <span>Revise quando e onde quiser.</span>
      </div>
      <div class="metric">
        <strong>Foco na prática</strong>
        <span>Aplicação direta no cuidado ao paciente.</span>
      </div>
    </section>

    <section class="landing-about" id="sobre" aria-label="Sobre">
      <h2>Sobre o Portal Enfermagem</h2>
      <p>Um espaço para estudar com agilidade: procedimentos, medicamentos, terminologias e quizzes em um só lugar.</p>
    </section>

    <section class="landing-contact" id="contato" aria-label="Contato">
      <h2>Contato</h2>
      <p class="landing-contact-text">Precisa de ajuda ou quer enviar sugestões? Fale com a gente pelo suporte do sistema.</p>
    </section>

    <footer class="landing-footer">Portal Enfermagem</footer>
  </main>
</body>
</html>

<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Portal Enfermagem</title>
  <link rel="stylesheet" href="/site/css/pages.css">
</head>
<body class="landing-page">
  <% const usuarioLocal = (typeof usuario !== 'undefined' && usuario) ? usuario : null; %>
  <header class="topbar">
    <div class="topbar-inner">
      <h1 class="brand"><img src="/site/img/logo.png" alt="Logo"></h1>
      <nav class="auth">
        <% if (usuarioLocal) { %>
          <a href="/usuario">Minha Conta</a>
        <% } else { %>
          <a href="/login">Entrar</a>
          <a href="/cadastro">Cadastre-se</a>
        <% } %>
      </nav>
      <div class="topbar-controls">
        <button type="button" class="topbar-btn" onclick="history.back()">Voltar</button>
        <% if (usuarioLocal) { %>
          <a class="topbar-btn" href="/sair">Sair</a>
        <% } else { %>
          <a class="topbar-btn" href="/login">Entrar</a>
        <% } %>

      </div>
    </div>
  </header>

  
  <main class="container">
    <% if (!usuarioLocal) { %>
      <section class="guest-hero">
        <h2>Seu apoio rápido na prática de enfermagem</h2>
        <p>Veja conteúdos introdutórios e exemplos visuais. Para acessar todos os módulos, faça login.</p>
        <a class="guest-cta" href="/login">Entrar e acessar tudo</a>
      </section>

      <section class="guest-grid" aria-label="Prévia de conteúdos">
        <div class="guest-card">
          <img src="/site/img/protocolo.png" alt="Prévia de procedimentos">
          <p>Protocolos essenciais em poucos cliques</p>
        </div>
        <div class="guest-card">
          <img src="/site/img/med.png" alt="Prévia de medicamentos">
          <p>Medicamentos organizados por classe</p>
        </div>
        <div class="guest-card">
          <img src="/site/img/termo.png" alt="Prévia de terminologias">
          <p>Termos e definições para revisão rápida</p>
        </div>
      </section>
    <% } else { %>
      <section class="hero">
        <h2>Seu apoio rápido na prática de enfermagem</h2>
        <p>Consulte conteúdos essenciais, revise protocolos, teste conhecimentos e organize sua rotina em um só lugar.</p>
      </section>

      <section class="section">
        <h3>Conteúdos e fotos</h3>
        <p class="muted">Acesse rapidamente os principais módulos com prévias visuais.</p>
        <div class="content-grid">
          <a class="content-card" href="/procedimentos">
            <img src="/site/img/product09.png" alt="Procedimentos">
            <div class="content-text">Procedimentos</div>
          </a>
          <a class="content-card" href="/medicamentos">
            <img src="/site/img/shop01.png" alt="Medicamentos">
            <div class="content-text">Medicamentos</div>
          </a>
          <a class="content-card" href="/terminologias">
            <img src="/site/img/shop02.png" alt="Terminologias">
            <div class="content-text">Terminologias</div>
          </a>
          <a class="content-card" href="/quiz">
            <img src="/site/img/shop03.png" alt="Quiz">
            <div class="content-text">Quiz</div>
          </a>
          <a class="content-card" href="/conteudos">
            <img src="/site/img/acessorio02.png" alt="Conteúdos">
            <div class="content-text">Conteúdos</div>
          </a>
        </div>
      </section>

      <section class="grid" aria-label="Resumo">
        <article class="card">
          <h3>Procedimentos</h3>
          <div class="value"><%= procedimentoCount %></div>
        </article>
        <article class="card">
          <h3>Medicamentos</h3>
          <div class="value"><%= medicamentoCount %></div>
        </article>
        <article class="card">
          <h3>Terminologias</h3>
          <div class="value"><%= termoCount %></div>
        </article>
      </section>

      <section class="section">
        <h3>Acessos rápidos</h3>
        <p class="muted">Abra direto o recurso que você precisa no momento.</p>
        <div class="links">
          <a href="/procedimentos">Consultar procedimentos</a>
          <a href="/medicamentos">Consultar medicamentos</a>
          <a href="/terminologias">Ver terminologias</a>
          <a href="/quiz">Responder quiz</a>
          <a href="/conteudos">Meus conteúdos (PDF)</a>
        </div>
      </section>
    <% } %>

    <div class="footer">Portal Enfermagem</div>
  </main>
</body>
</html>

<%- include('cabecalho', { pageClass: 'page-usuario' }) %>
<% const user = (typeof dadosUsuario !== 'undefined' && dadosUsuario) ? dadosUsuario : null; %>
<% const conteudosCountLocal = (typeof conteudosCount !== 'undefined' && Number.isFinite(conteudosCount)) ? conteudosCount : 0; %>
<% const conteudosRecentesLocal = (typeof conteudosRecentes !== 'undefined' && conteudosRecentes) ? conteudosRecentes : []; %>
<% const formatDate = (value) => { try { if (!value) return ''; const d = new Date(value); if (Number.isNaN(d.getTime())) return ''; return d.toLocaleDateString('pt-BR'); } catch (e) { return ''; } }; %>

<section class="page-hero user-page-header">
  <div>
    <p class="page-eyebrow">Área do usuário</p>
    <h2 class="user-page-title">Minha conta</h2>
    <p class="user-page-subtitle">Seus dados e seus PDFs, organizados em um só lugar.</p>
  </div>
  <div class="page-hero-stat">
    <strong><%= conteudosCountLocal %></strong>
    <span>PDF(s)</span>
  </div>
</section>

<% if (user) { %>
  <section class="app-card user-hero" aria-label="Resumo do usuário">
    <div class="user-hero-avatar">
      <% if (user.foto) { %>
        <img src="/usuarios/<%= user.foto %>" alt="Foto do usuário" class="user-hero-avatar-img">
      <% } else { %>
        <div class="user-hero-avatar-placeholder" aria-hidden="true">
          <%= user.nome ? user.nome.trim().charAt(0).toUpperCase() : '?' %>
        </div>
      <% } %>
    </div>

    <div class="user-hero-main">
      <div class="user-hero-title">
        Bem-vindo, <strong><%= user.nome %></strong>
      </div>
      <div class="user-hero-meta">
        <span><%= user.email %></span>
        <% if (user.telefone) { %>
          <span class="user-hero-dot" aria-hidden="true">•</span>
          <span><%= user.telefone %></span>
        <% } %>
      </div>
      <div class="user-hero-hint">
        Aqui você acessa apenas conteúdos publicados pelo administrador.
      </div>
      <div class="user-hero-actions">
        <a class="user-btn primary" href="/usuario/editar">Editar meus dados</a>
        <a class="user-btn" href="/conteudos">Meus PDFs</a>
      </div>
    </div>

    <div class="user-hero-stats" aria-label="Resumo de PDFs">
      <div class="user-stat">
        <div class="user-stat-label">PDFs enviados</div>
        <div class="user-stat-value"><%= conteudosCountLocal %></div>
      </div>
    </div>
  </section>

  <div class="user-layout">
    <section class="app-card user-panel" aria-label="Meus dados">
      <div class="user-panel-header">
        <h3 class="user-panel-title">Meus dados</h3>
        <a class="user-panel-link" href="/usuario/editar">Editar</a>
      </div>

      <dl class="user-data-grid">
        <div class="user-data-item">
          <dt>Nome</dt>
          <dd><%= user.nome %></dd>
        </div>
        <div class="user-data-item">
          <dt>E-mail</dt>
          <dd><%= user.email %></dd>
        </div>
        <div class="user-data-item">
          <dt>Telefone</dt>
          <dd><%= user.telefone || 'não informado' %></dd>
        </div>
        <div class="user-data-item">
          <dt>Endereço</dt>
          <dd><%= user.endereco || 'não informado' %></dd>
        </div>
        <div class="user-data-item">
          <dt>CPF</dt>
          <dd><%= user.cpf || 'não informado' %></dd>
        </div>
        <div class="user-data-item">
          <dt>Data de nascimento</dt>
          <dd><%= formatDate(user.datanasc) || 'não informada' %></dd>
        </div>
      </dl>
    </section>

    <section class="app-card user-panel" aria-label="Meus conteúdos em PDF">
      <div class="user-panel-header">
        <h3 class="user-panel-title">Meus conteúdos (PDF)</h3>
        <a class="user-panel-link" href="/conteudos">Abrir</a>
      </div>

      <% if (!conteudosRecentesLocal.length) { %>
        <div class="app-empty user-empty">Nenhum PDF enviado ainda. Envie seu primeiro conteúdo para começar.</div>
      <% } else { %>
        <ul class="user-pdf-list" aria-label="Últimos PDFs">
          <% conteudosRecentesLocal.slice(0, 5).forEach(function(c){ %>
            <li class="user-pdf-item">
              <div class="user-pdf-title"><%= c.titulo %></div>
              <div class="user-pdf-meta">
                <% const created = formatDate(c.criadoEm); %>
                <% if (created) { %><span><%= created %></span><% } %>
                <% if (c.categoria) { %>
                  <% if (created) { %><span class="user-hero-dot" aria-hidden="true">•</span><% } %>
                  <span class="user-pill"><%= c.categoria %></span>
                <% } %>
              </div>
            </li>
          <% }) %>
        </ul>

        <% if (conteudosRecentesLocal.length > 5) { %>
          <div class="muted-text user-more">E mais <%= conteudosRecentesLocal.length - 5 %> PDF(s)…</div>
        <% } %>
      <% } %>

      <div class="user-panel-actions">
        <a class="user-btn primary" href="/conteudos">Ver e organizar meus PDFs</a>
      </div>
    </section>
  </div>
<% } else { %>
  <p class="muted-text">Sua sessão não está ativa. Faça login para acessar sua conta.</p>
  <div class="user-panel-actions">
    <a class="user-btn primary" href="/login">Entrar</a>
  </div>
<% } %>

<%- include('rodape') %>

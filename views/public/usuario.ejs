<%- include('cabecalho', { pageClass: 'page-usuario' }) %>
<h2>Área do Usuário</h2>
<% if (typeof dadosUsuario !== 'undefined' && dadosUsuario) { %>
  <div class="user-banner">
    <div class="user-banner-avatar-wrap">
      <% if (dadosUsuario.foto) { %>
        <img src="/usuarios/<%= dadosUsuario.foto %>" alt="Foto do usuário" class="user-banner-avatar">
      <% } else { %>
        <div class="user-banner-avatar-placeholder">
          <%= dadosUsuario.nome ? dadosUsuario.nome.charAt(0).toUpperCase() : '?' %>
        </div>
      <% } %>
    </div>
    <div>
      Bem-vindo, <strong><%= dadosUsuario.nome %></strong>! Aqui você acessa apenas conteúdos publicados pelo administrador.
    </div>
  </div>
<% } else { %>
  <p>Bem-vindo. Aqui você acessa apenas conteúdos publicados pelo administrador.</p>
<% } %>

<% if (typeof dadosUsuario !== 'undefined' && dadosUsuario) { %>


  <section class="user-card">
    <h3 class="user-card-title">Meus dados</h3>
    <div class="user-card-top">
      <% if (dadosUsuario.foto) { %>
        <img src="/usuarios/<%= dadosUsuario.foto %>" alt="Foto do usuário" class="user-card-avatar">
      <% } else { %>
        <div class="user-card-avatar-placeholder">
          <%= dadosUsuario.nome ? dadosUsuario.nome.charAt(0).toUpperCase() : '?' %>
        </div>
      <% } %>
      <div class="user-card-note">
        Você pode editar seus dados e trocar sua foto de perfil.
      </div>
    </div>
    <ul class="user-data-list">
      <li><strong>Nome:</strong> <%= dadosUsuario.nome %></li>
      <li><strong>E-mail:</strong> <%= dadosUsuario.email %></li>
      <li><strong>Telefone:</strong> <%= dadosUsuario.telefone || 'não informado' %></li>
      <li><strong>Endereço:</strong> <%= dadosUsuario.endereco || 'não informado' %></li>
      <li><strong>CPF:</strong> <%= dadosUsuario.cpf || 'não informado' %></li>
      <li><strong>Data de nascimento:</strong> <%= dadosUsuario.datanasc ? dadosUsuario.datanasc.toISOString().substr(0,10) : 'não informada' %></li>
    </ul>
    <div class="user-card-actions">
      <a href="/usuario/editar">Editar meus dados e foto</a>
    </div>
  </section>
<% } %>

<% if (typeof lembretesProximos !== 'undefined' && lembretesProximos.length) { %>
  <div class="user-reminder-box">
    <strong>Você tem lembretes vencendo em até 3 dias:</strong>
    <ul>
      <% lembretesProximos.forEach(function(l){ %>
        <li>
          <%= l.conteudo %>
          <% if (l.vencimento) { %>
            - <%= l.vencimento.toISOString().substr(0,10) %>
            <% if (agora && l.vencimento <= agora) { %>
              <strong class="text-danger">(vencido)</strong>
            <% } %>
          <% } else { %>
            - sem data
          <% } %>
        </li>
      <% }) %>
    </ul>
    <a href="/lembretes">Ver todos os lembretes</a>
  </div>
<% } %>

<%- include('rodape') %>

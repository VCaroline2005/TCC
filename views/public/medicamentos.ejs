<%- include('cabecalho') %>
<% const pesquisaAtual = (typeof pesquisar !== 'undefined' && pesquisar) ? pesquisar : ''; %>
<% const classesDisponiveis = (typeof classes !== 'undefined' && classes) ? classes : []; %>
<% const classeAtual = (typeof classeSelecionada !== 'undefined' && classeSelecionada) ? classeSelecionada : ''; %>
<style>
  .med-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
    font-size: 14px;
  }
  .med-table th,
  .med-table td {
    border: 1px solid #000;
    padding: 8px;
    text-align: left;
    vertical-align: top;
  }
  .med-table th {
    background: #f3f4f6;
  }
  .med-table tbody tr:nth-child(even) {
    background: #fafafa;
  }
  .med-preline {
    white-space: pre-line;
  }
</style>

<h2>Medicamentos</h2>
<form method="get" action="/medicamentos" style="margin-bottom:14px;">
  <input
    type="text"
    name="pesquisar"
    placeholder="Pesquisar princípio ativo, nome comercial, classe, via ou diluição"
    value="<%= pesquisaAtual %>"
    style="padding:8px; width:100%; max-width:520px; border:1px solid #000; border-radius:4px;"
  >
  <button type="submit" style="padding:8px 12px; margin-left:6px; background:#a51b0b; color:#fff; border:1px solid #000; border-radius:4px; cursor:pointer;">
    Pesquisar
  </button>
  <select name="classe" style="padding:8px; margin-left:6px; border:1px solid #000; border-radius:4px;">
    <option value="">Todas as classes</option>
    <% classesDisponiveis.forEach(function(c){ %>
      <option value="<%= c %>" <%= classeAtual === c ? 'selected' : '' %>><%= c %></option>
    <% }) %>
  </select>
</form>
<% if (!Medicamentos || Medicamentos.length === 0) { %>
  <p>Nenhum medicamento encontrado para o filtro informado.</p>
<% } else { %>
  <table class="med-table" aria-label="Tabela de medicamentos">
    <thead>
      <tr>
        <th>Princípio ativo</th>
        <th>Nome comercial</th>
        <th>Classe</th>
        <th>Via</th>
        <th>Diluição</th>
      </tr>
    </thead>
    <tbody>
      <% Medicamentos.forEach(function(m){ %>
        <% const principioAtivo = m.principioAtivo || m.descricao || '-'; %>
         <% const nomeComercial = m.nomeComercial || m.nome || '-'; %>
        <% const classe = m.classe || m.fabricante || '-'; %>
        <% const via = m.via || '-'; %>
        <% const diluicao = m.diluicao || m.dosagem || '-'; %>
        <tr>
          <td><%= principioAtivo %></td>
          <td><%= nomeComercial %></td>
          <td><%= classe %></td>
          <td class="med-preline"><%= via %></td>
          <td class="med-preline"><%= diluicao %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
<%- include('rodape') %>

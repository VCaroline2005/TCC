<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Portal Enfermagem</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

    <header class="auth-topbar">
      <div class="bar-inner">
        <div class="brand">
          <a href="/"><img class="logo" src="/site/img/logo.png" alt="Portal Enfermagem"></a>
          <h1>Portal Enfermagem</h1>
        </div>
        <div class="nav-controls">
          <button type="button" class="nav-btn" onclick="history.back()">Voltar</button>
          <a class="nav-btn" href="/sair">Sair</a>
          <button type="button" class="nav-btn" onclick="history.forward()">Avançar</button>
        </div>
      </div>
    </header>

    <main class="auth-main">
    <div class="login-container">
    <h2>Bem-vindo ao seu Manual</h2>
    <p>Faça login em sua conta para ter acesso a conteúdos </p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="color:#c0392b; margin-bottom:12px;"><%= error %></div>
    <% } %>
    <% if (typeof cadastro !== 'undefined' && cadastro === 'ok') { %>
      <div style="color:#a51b0b; margin-bottom:12px;">Cadastro realizado com sucesso. Faça login.</div>
    <% } %>
    
    <form action="/login" method="POST">
      
      <!-- Campo para o nome de usuário -->
      <div class="input-group">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email" placeholder="Digite seu e-mail" required>
      </div>
      
      <!-- Campo para a senha -->
      <div class="input-group">
        <label for="password">Senha</label>
        <input type="password" id="password" name="password" placeholder="Digite sua senha" required>
      </div>
      
      <!-- Botão de login -->
      <button type="submit" class="btn-submit">Entrar</button>
      
      <!-- Links de recuperação de senha e criação de conta -->
      <div class="footer">
        <a href="#">Esqueceu a senha?</a><br>
        <a href="/cadastro">Ainda não tem uma conta? Cadastre-se aqui</a>
      </div>
    </form>
    </div>
    </main>
      <style>
  /* Estilos globais */
  body {
    font-family: 'Arial', sans-serif;
    background-color: #f4f4f4;
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .auth-topbar {
    background: linear-gradient(90deg, #a51b0b 0%, #6f1208 45%, #160504 100%);
    color: #fff;
    padding: 14px 16px;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.18);
  }

  .auth-topbar .bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    max-width: 1100px;
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .auth-topbar .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .auth-topbar h1 {
    margin: 0;
    font-size: 20px;
  }

  .auth-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
  }

  .nav-controls {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .nav-btn {
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.28);
    color: #fff;
    padding: 6px 10px;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }

  .nav-btn:hover {
    background: rgba(255,255,255,0.22);
  }
  
  /* Contêiner do formulário de login */
  .login-container {
    background-color: #f4f4f4;
    padding: 40px;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 400px;
    text-align: center;
  }

  .logo {
    display: block;
    height: 44px;
    width: auto;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.35));
  }
  
  /* Título do formulário */
  h2 {
    color: #000;
    margin-bottom: 15px;
  }
  
  /* Subtítulo do formulário */
  p {
    color: #000;
    font-size: 14px;
    margin-bottom: 25px;
  }
  
  /* Estilo para os campos de entrada */
  .input-group {
    margin-bottom: 20px;
    text-align: left;
  }
  
  .input-group label {
    display: block;
    font-weight: bold;
    color: #000;
  }
  
  .input-group input {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    border: 1px solid #000;
    border-radius: 4px;
    font-size: 14px;
    color: #000;
  }
  
  .input-group input:focus {
    border-color: #a51b0b; /* Cor laranja para destacar o foco */
    outline: none;
  }
  
  
  .btn-submit {
    width: 100%;
    padding: 12px;
    background-color: #a51b0b; /* Laranja */
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
  }
  
  .btn-submit:hover {
    background-color: #a51b0b;
  }
  
  /* Links de recuperação de senha e cadastro */
  .footer {
    margin-top: 20px;
  }
  
  .footer a {
    color: #a51b0b;
    text-decoration: none;
    font-size: 14px;
  }
  
  .footer a:hover {
    text-decoration: underline;
  }
  </style>

</body>
</html>
